@article{clementXLFGanLFGParsing,
	title = {{XLFG}-an {LFG} parsing scheme for {French}},
	abstract = {We present XLFG, a new parser for LFG developed by Lionel Cle´ment (Cle´ment 2000), (Cle´ment 2001b). This parser is freely available for pedagogical as well as for research purpose. In this paper, we explain how the tool has been used to develop and evaluate a medium-size LFG for French. We also show how we have exploited the similarities between the LFG and the Tree Adjoining Grammar Frameworks in order to integrate into XLFG a rule-based parse-ranker for French.},
	language = {en},
	author = {Clement, Lionel and Kinyon, Alexandra},
}

