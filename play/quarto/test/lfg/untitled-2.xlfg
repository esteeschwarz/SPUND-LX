    <LEXICON><![CDATA[niemand pro[PRED:&apos;NOBODY&apos;, NUMBER:sg, PERSON:_3, CASE:nom];
Niemand pro[PRED:&apos;NOBODY&apos;, NUMBER:sg, PERSON:_3, CASE:nom];

hat verb[TENSE:perfect, MODE:indicative];

diesem det[DEM:+, NUMBER:sg];
Diesem det[DEM:+, NUMBER:sg];
einem det[DEM:-, NUMBER:sg, GENDER:m];

Mann noun[PRED:&apos;MAN&apos;, CASE:dat, GENDER:m];

das det[DEF:+, NUMBER:sg];
Das det[DEF:+, NUMBER:sg];

Buch noun[PRED:&apos;BOOK&apos;, CASE:acc, GENDER:n];

&quot;zu lesen&quot; verb[PRED:&apos;TO_READ&lt;SUBJ.agent, OBJ.object&gt;&apos;];
&quot;Zu lesen&quot; verb[PRED:&apos;TO_READ&lt;SUBJ.agent, OBJ.object&gt;&apos;];
zu part;
Zu part;
lesen verb;

versprochen verb[PRED:&apos;PROMISE&lt;SUBJ.agent, XCOMP.object, IOBJ.recipient&gt;&apos;/*, TENSE:past*/]
{
	(↑ XCOMP SUBJ) = (↑ SUBJ);
};
]]></LEXICON>
    <GRAMMAR><![CDATA[MainDomain → Vorfeld LeftBracket [Mittelfeld] [RightBracket] [Nachfeld]
{
↑=↓1;
↑=↓2;
↑=↓3;
↑=↓4;
↑=↓5;
}

EmbeddedDomain → [Mittelfeld] RightBracket [Nachfeld]
{
↑=↓1;
↑=↓2;
↑=↓3;
}

////////////////////////////////////////////////////////////
// Vorfeld
////////////////////////////////////////////////////////////
Vorfeld → _XF
{
↑=↓1;
}

Vorfeld → EmbeddedDomain
{
(↑ XCOMP) =↓1;
}

XF → ADVP
{
let comp in (↑ (XCOMP)* ) { ↓1 ∈ (comp ADJUNCT); }
}

////////////////////////////////////////////////////////////
// LeftBracket
////////////////////////////////////////////////////////////
LeftBracket → verb
{
↑=↓1;
}

////////////////////////////////////////////////////////////
// Mittelfeld
////////////////////////////////////////////////////////////
Mittelfeld → _XF
{
↑=↓1;
}

Mittelfeld → _XF  _XF [_XF]
{
↑=↓1;
↑=↓2;
↑=↓3;
}

////////////////////////////////////////////////////////////
// RightBracket
////////////////////////////////////////////////////////////
RightBracket → VerbCluster
{
↑ = ↓;
}

RightBracket → VerbCluster
{
(↑ XCOMP) = ↓;
}

////////////////////////////////////////////////////////////
// Nachfeld
////////////////////////////////////////////////////////////
// Too ambiguous !
/*
Nachfeld → _XF [_XF] 
{
↑=↓1;
↑=↓2;
}

Nachfeld → EmbeddedDomain
{
(↑ XCOMP) = ↓1;
}
*/

_XF → NP
{
(↑ SUBJ) = ↓1; 
(↓1 CASE) = nom; 
(↓ GENDER) = u; 
}

_XF → NP
{
(↑ OBJ) = ↓1; 
(↓1 CASE) = acc; 
(↓ GENDER) = n; 
}

_XF → NP
{
(↑ IOBJ) = ↓1; 
}

_XF → NP
{
(↑ XCOMP OBJ) = ↓1; 
(↓1 CASE) = acc; 
(↓ GENDER) = n; 
}

_XF → NP
{
(↑ XCOMP IOBJ) = ↓1; 
(↓ GENDER) = m; 
}

VerbCluster → [Oberfeld] _H [Unterfeld]
{
↑=↓1;
↑=↓2;
↑=↓3;
}

VerbBox → [Oberfeld] _H
{
↑=↓1;
↑=↓2;
}

_H → verb
{
↑=↓;
}

Oberfeld → VerbBox
{
//with $xcomp in (↑ (XCOMP)+ ) { $xcomp = ↓1; }
(↑ XCOMP) = ↓; 
}

Unterfeld → VerbCluster
{
(↑ XCOMP) =↓1;
(↑ TYPE) = aux;
(↑ MODAL) = +;
(↑ ERSATZ) = +;
(↑ TENSE) ≠ zu_inf;
}

NP → pro
{
↑ = ↓1;
}

NP → det noun 
{
↑ = ↓1;
↑ = ↓2;
(↑ PERSON) = _3;
(↑ GENDER) = m;
}

]]></GRAMMAR>
