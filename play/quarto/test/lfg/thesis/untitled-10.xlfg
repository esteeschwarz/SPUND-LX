<?xml version="1.0" encoding="UTF-8"?>
<XLFG version="9.16.2">
  <VERSION id_project="5844" id_version="7947">
    <SENTENCES>
      <SENTENCE GRAMMATICAL="1"><![CDATA[אני הלך]]></SENTENCE>
      <SENTENCE GRAMMATICAL="1"><![CDATA[הגבר]]></SENTENCE>
    </SENTENCES>
    <DECLARATIONS><![CDATA[                // Macros
@s: number:sg;
@p: number:pl;
@m: gender:masc;
@f: gender:fem;
@mf: gender:masc|fem;
@ms: @m, @s;
@fs: @f, @s;
@mp: @m, @p;
@fp: @f, @p;

// Declared syntactic functions
syntactic functions: SUBJ, OBJ, POBJ;

start_symbol: S;                            ]]></DECLARATIONS>
    <LEXICON><![CDATA[ani pr[PRED:&apos;ANI&apos;, @s];
ani pr[PRED:&apos;ANI&apos;, @s];
&quot;אני&quot; pr[PRED:&apos;ANI&apos;, @ms];
&quot;אתה&quot; pr[PRED:&apos;ATA&apos;, @ms];
&quot;את&quot; pr[PRED:&apos;AT&apos;, @fs];
&quot;הוא&quot; pr[PRED:&apos;HU&apos;, @ms];
&quot;היא&quot; pr[PRED:&apos;HI&apos;, @fs];
&quot;אנחנו&quot; pr[PRED:&apos;ANACHNU&apos;, @p];
&quot;הם&quot; pr[PRED:&apos;HEM&apos;, @mp];
&quot;הן&quot; pr[PRED:&apos;HEN&apos;, @fp];

&quot;הלך&quot; v[PRED:&apos;HALACH &lt;SUBJ.agent&gt;&apos;, @ms];
&quot;הלכה&quot; v[PRED:&apos;HALACH &lt;SUBJ.agent&gt;&apos;, @fs];
&quot;הולכים&quot; v[PRED:&apos;HALACH &lt;SUBJ.agent&gt;&apos;, @mp];
&quot;אכל&quot; v[PRED:&apos;ACHAL &lt;SUBJ.agent, OBJ.patient&gt;&apos;, @ms];
&quot;אכלה&quot; v[PRED:&apos;ACHAL &lt;SUBJ.agent, OBJ.patient&gt;&apos;, @fs];
&quot;אוכלים&quot; v[PRED:&apos;ACHAL &lt;SUBJ.agent, OBJ.patient&gt;&apos;, @mp];

///
/// %%% ===== BINYAN: PA&apos;AL (simple active) =====
&quot;הלך&quot; v[PRED:&apos;HALACH &lt;SUBJ.agent&gt;&apos;, TENSE:past, VOICE:active, BINYAN:&apos;PAAL&apos;, @ms];
&quot;הלכה&quot; v[PRED:&apos;HALACH &lt;SUBJ.agent&gt;&apos;, TENSE:past, VOICE:active, BINYAN:&apos;PAAL&apos;, @fs];
&quot;הלכו&quot; v[PRED:&apos;HALACH &lt;SUBJ.agent&gt;&apos;, TENSE:past, VOICE:active, BINYAN:&apos;PAAL&apos;, @p];

&quot;הולך&quot; v[PRED:&apos;HALACH &lt;SUBJ.agent&gt;&apos;, TENSE:pres, VOICE:active, BINYAN:&apos;PAAL&apos;, @ms];
&quot;הולכת&quot; v[PRED:&apos;HALACH &lt;SUBJ.agent&gt;&apos;, TENSE:pres, VOICE:active, BINYAN:&apos;PAAL&apos;, @fs];
&quot;הולכים&quot; v[PRED:&apos;HALACH &lt;SUBJ.agent&gt;&apos;, TENSE:pres, VOICE:active, BINYAN:&apos;PAAL&apos;, @mp];
&quot;הולכות&quot; v[PRED:&apos;HALACH &lt;SUBJ.agent&gt;&apos;, TENSE:pres, VOICE:active, BINYAN:&apos;PAAL&apos;, @fp];

/// %%% ===== BINYAN: PI&apos;EL (intensive active) =====
&quot;סיפר&quot; v[PRED:&apos;SIPER &lt;SUBJ.agent, OBJ.patient&gt;&apos;, TENSE:past, VOICE:active, BINYAN:&apos;PIEL&apos;, @ms];
&quot;מספר&quot; v[PRED:&apos;SIPER &lt;SUBJ.agent, OBJ.patient&gt;&apos;, TENSE:pres, VOICE:active, BINYAN:&apos;PIEL&apos;, @ms];

/// %%% ===== BINYAN: HIF&apos;IL (causative active) =====
&quot;הסביר&quot; v[PRED:&apos;HESBIR &lt;SUBJ.agent, OBJ.patient&gt;&apos;, TENSE:past, VOICE:active, BINYAN:&apos;HIFIL&apos;, @ms];
&quot;מסביר&quot; v[PRED:&apos;HESBIR &lt;SUBJ.agent, OBJ.patient&gt;&apos;, TENSE:pres, VOICE:active, BINYAN:&apos;HIFIL&apos;, @ms];

/// %%% ===== BINYAN: NIF&apos;AL (simple passive) =====
&quot;נאמר&quot; v[PRED:&apos;NEEMAR &lt;SUBJ.patient&gt;&apos;, TENSE:past, VOICE:passive, BINYAN:&apos;NIFAL&apos;, @ms];
&quot;נאמרה&quot; v[PRED:&apos;NEEMAR &lt;SUBJ.patient&gt;&apos;, TENSE:past, VOICE:passive, BINYAN:&apos;NIFAL&apos;, @fs];
&quot;נמצא&quot; v[PRED:&apos;NIMZA &lt;SUBJ.patient&gt;&apos;, TENSE:past, VOICE:passive, BINYAN:&apos;NIFAL&apos;, @ms];

&quot;נאמרים&quot; v[PRED:&apos;NEEMAR &lt;SUBJ.patient&gt;&apos;, TENSE:pres, VOICE:passive, BINYAN:&apos;NIFAL&apos;, @mp];
&quot;נאמרות&quot; v[PRED:&apos;NEEMAR &lt;SUBJ.patient&gt;&apos;, TENSE:pres, VOICE:passive, BINYAN:&apos;NIFAL&apos;, @fp];

/// %%% ===== BINYAN: PU&apos;AL (intensive passive) =====
&quot;סופר&quot; v[PRED:&apos;SUPAR &lt;SUBJ.patient&gt;&apos;, TENSE:past, VOICE:passive, BINYAN:&apos;PUAL&apos;, @ms];

/// %%% ===== BINYAN: HUF&apos;AL (causative passive) =====
&quot;הוסבר&quot; v[PRED:&apos;HUSBAR &lt;SUBJ.patient&gt;&apos;, TENSE:past, VOICE:passive, BINYAN:&apos;HUFAL&apos;, @ms];

/// %%% ===== FUTURE TENSE (PA&apos;AL examples) =====
&quot;אלך&quot; v[PRED:&apos;HALACH &lt;SUBJ.agent&gt;&apos;, TENSE:future, VOICE:active, BINYAN:&apos;PAAL&apos;, @s];
&quot;ילך&quot; v[PRED:&apos;HALACH &lt;SUBJ.agent&gt;&apos;, TENSE:future, VOICE:active, BINYAN:&apos;PAAL&apos;, @ms];
&quot;תלך&quot; v[PRED:&apos;HALACH &lt;SUBJ.agent&gt;&apos;, TENSE:future, VOICE:active, BINYAN:&apos;PAAL&apos;, @fs];
&quot;ילכו&quot; v[PRED:&apos;HALACH &lt;SUBJ.agent&gt;&apos;, TENSE:future, VOICE:active, BINYAN:&apos;PAAL&apos;, @p];

///

&quot;ילד&quot; cn[PRED:&apos;YELED&apos;, @ms];
&quot;ילדה&quot; cn[PRED:&apos;YALDA&apos;, @fs];
&quot;ילדים&quot; cn[PRED:&apos;YELED&apos;, @mp];
&quot;ספר&quot; cn[PRED:&apos;SEFER&apos;, @ms];
&quot;ספרים&quot; cn[PRED:&apos;SEFER&apos;, @mp];
&quot;בית&quot; cn[PRED:&apos;BAYIT&apos;, @ms];
&quot;הורים&quot; cn[PRED:&apos;HORE&apos;, @mp];
&quot;מוזיקה&quot; cn[PRED:&apos;MUSICA&apos;, @fs];
&quot;זמן&quot; cn[PRED:&apos;ZMAN&apos;, @ms];
&quot;טלסקופ&quot; cn[PRED:&apos;TELESCOPE&apos;, @ms];
&quot;יום&quot; cn[PRED:&apos;YOM&apos;, @ms];
&quot;איש&quot; cn[PRED:&apos;ISH&apos;, @ms];

&quot;גביע&quot; cn[PRED:&apos;GEVIAH&apos;, @ms];
&quot;יד&quot; cn[PRED:&apos;JAD&apos;, @ms];
&quot;איש&quot; cn[PRED:&apos;ISH&apos;, @ms];

&quot;ה&quot; det[@s];
&quot;כל&quot; det[@s];
&quot;כל־ה&quot; det[@s];
&quot;כל־ה־&quot; det[@s];

///%%% ===== PREFIXES =====
&quot;ה&quot; pref[PRED:&apos;DEF&apos;];
&quot;ל&quot; pref[PRED:&apos;TO&apos;];
&quot;מ&quot; pref[PRED:&apos;FROM&apos;];
&quot;ב&quot; pref[PRED:&apos;IN&apos;];
&quot;כ&quot; pref[PRED:&apos;AS&apos;];




&quot;ב&quot; prep[PRED:&apos;BE &lt;OBJ&gt;&apos; ];
&quot;ל&quot; prep[PRED:&apos;LE &lt;OBJ&gt;&apos; ];
&quot;על&quot; prep[PRED:&apos;AL &lt;OBJ&gt;&apos; ];
&quot;עם&quot; prep[PRED:&apos;IM &lt;OBJ&gt;&apos; ];

&quot;גדול&quot; adj[PRED:&apos;GADOL&apos;];
&quot;קטן&quot; adj[PRED:&apos;KATAN&apos;];
&quot;חדש&quot; adj[PRED:&apos;CHADASH&apos;];
&quot;ישן&quot; adj[PRED:&apos;YASHAN&apos;];
]]></LEXICON>
    <GRAMMAR><![CDATA[S → NP VP
{
(↑ SUBJ) = ↓1;
↑ = ↓2;
}

NP → [det] det N
{
↑ = ↓2;
↑ = ↓3;
}

NP → N
{
↑ = ↓1;
}

N → cn
{
↑ = ↓1;
}

NP → pn
{
↑ = ↓1;
}

NP → pr
{
↑ = ↓1;
}

VP → v [NP] [PP]
{
↑ = ↓1;
(↑ OBJ) = ↓2;
(↑ POBJ) = ↓3;
}

VP → v [PP]
{
↑ = ↓1;
(↑ OBJ) = ↓2;
}

VP → v adj
{
↑ = ↓1;
(↑ OBJ) = ↓2;
}

VP → v NP PP
{
↑ = ↓1;
(↑ OBJ) = ↓2;
↓3 ∈ (↑ MOD);
}

VP → v PP NP
{
↑ = ↓1;
(↑ OBJ) = ↓2;
↓3 ∈ (↑ MOD);
}

N → N PP
{
↑ = ↓1;
↓2 ∈ (↑ MOD);
}

PP → prep NP
{
↑ = ↓1;
(↑ OBJ) = ↓2;
}

PP → NP
{
↑ = ↓1;
}

///
/// %%% ===== VP tense propagation =====
VP → v
{
↑ = ↓1;
(↑ TENSE) = (↓1 TENSE);
(↑ VOICE) = (↓1 VOICE);
(↑ BINYAN) = (↓1 BINYAN);
}

VP → v
{
↑ = ↓1;
(↑ SUBJ) = (↓1 SUBJ);
(↑ TENSE) = (↓1 TENSE);
(↑ VOICE) = (↓1 VOICE);
(↑ BINYAN) = (↓1 BINYAN);
}

VP → v NP
{
↑ = ↓1;
(↑ OBJ) = ↓2;
(↑ TENSE) = (↓1 TENSE);
(↑ VOICE) = (↓1 VOICE);
(↑ BINYAN) = (↓1 BINYAN);
}

VP → v PP
{
↑ = ↓1;
(↑ POBJ) = ↓2;
(↑ TENSE) = (↓1 TENSE);
(↑ VOICE) = (↓1 VOICE);
(↑ BINYAN) = (↓1 BINYAN);
}

//%%% ===== Passive subject mapping =====
VP → v
{
↑ = ↓1;
}
///%%% Passive binyanim: SUBJ = patient
//(↓1 VOICE) = &apos;passive&apos; ⇒ (↑ SUBJ) = (↑ OBJ);

///%%% Active binyanim: SUBJ = agent (default)
//(↓1 VOICE) = active ⇒ (↑ SUBJ) = (↓1 SUBJ);


///%%% ===== Binyan modifiers (optional) =====
//VP → v
//{
//(↓1 BINYAN) = &apos;PAAL&apos;  ⇒ (↑ ASPECT) = simple;
//(↓1 BINYAN) = &apos;PIEL&apos;  ⇒ (↑ ASPECT) = intensive;
//(↓1 BINYAN) = &apos;HIFIL&apos; ⇒ (↑ ASPECT) = causative;
//(↓1 BINYAN) = &apos;NIFAL&apos; ⇒ (↑ VOICE) = passive;
//(↓1 BINYAN) = &apos;PUAL&apos;  ⇒ (↑ VOICE) = passive;
//(↓1 BINYAN) = &apos;HUFAL&apos; ⇒ (↑ VOICE) = passive;
//}


//%%% ===== PREFIX + NOUN COMPOSITION =====
NP → pref N
{
↑ = ↓2;              
(↑ PREFIX) = ↓1;     
}

PP → pref N
{
↑ = ↓1;              
(↑ OBJ) = ↓2;
}

]]></GRAMMAR>
    <OUTPUT_PARAMETERS SCALE="1" DRAWFSA="WORDS" DRAWCS="TREE" DRAWFS="MATRIX" DRAWFE="SYNTACTICAL" DRAWAS="DAG" DRAWOPTIONAL="0" DRAWILLFORMEDFS="1" PARTIALCS="0" COMPACTFS="0" COMPLETENESS="1" COHERENCE="1" CONSISTENCY="1"/>
  </VERSION>
</XLFG>
