@article{langlois_distributed_2019,
	address = {Toronto},
	title = {Distributed {Intelligence}: {Silk} {Weaving} and the {Jacquard} {Mechanism}},
	volume = {44},
	copyright = {Copyright Canadian Journal of Communications Corporation 2019},
	issn = {0705-3657},
	abstract = {Background Launched in the early 1800s in Lyon, France, the Jacquard mechanism is often seen as the precursor for today’s software systems, enabling greater productivity in the automated industrial production of woven fabric. Analysis Based on archival research, this media archaeology article argues that the Jacquard mechanism enabled a new form of textile-based digital imaging. Lyon weavers used the mechanism to augment human imagination and strive for increased complexity in their quest for making textiles compete with the dominant media of the time (etching, printing, painting) and with the new medium of photography. Conclusion and implications Such augmentation of human intelligence and imagination brings to light the possibility for alternative relationships between human bodies and brains and digital systems based on collaboration rather than subsumption.},
	language = {eng},
	number = {4},
	journal = {Canadian journal of communication},
	publisher = {University of Toronto Press},
	author = {Langlois, Ganaele},
	year = {2019},
	note = {langlois-2019-distributed-intelligence-silk-weaving-and-the-jacquard-mechanism.pdf},
	keywords = {19th century, Actor-network theory, Archaeology, Artisans, Digital images, Digital media, Human body, Imagination, Industries, Overproduction, Photography, Productivity, Silk, Social networks, Software, Supply and demand, Textile fabrics, Weaving},
	pages = {555--566},
}

