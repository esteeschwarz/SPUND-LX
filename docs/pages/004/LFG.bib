
@incollection{bresnan_lexicality_2015,
	title = {Lexicality and {Argument} {Structure}},
	isbn = {978-1-119-10566-4},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.1002/9781119105664.ch3},
	doi = {https://doi.org/10.1002/9781119105664.ch3},
	abstract = {Summary This chapter considers evidence for the lexicality of the passive. It contrasts the syntactic and lexical analyses of the passive voice alternation, and seeks evidence for choosing between them. It is important to note that even the syntactic analysis is partly lexical, in the sense that the active and passive forms of the verb must be specified differently in order to trigger different syntactic effects. The chapter presents an argument for the lexical analysis based upon a demonstration that the subject argument is already specified in the verb's lexical entry. There is no need to postulate a separate rule of adjectival passivization in addition to verb passivization to explain the differences between adjectival and verbal passives. Both present and past participles in English undergo conversion to adjectives. A simple generalization applies to all participle–adjective conversion: the adjective preserves the subject of predication of its verbal base.},
	booktitle = {Lexical‐{Functional} {Syntax}},
	publisher = {John Wiley \& Sons, Ltd},
	author = {Bresnan, Joan and {Asudeh} and {Toivonen} and {Wechsler}},
	year = {2015},
	note = {Bresnan et al.\_2015\_Abschnitt\_3\_S\_21\_36.pdf},
	keywords = {argument structure, lexicality of passivization, participle–adjective conversion, passive relation changes, syntactic movements},
	pages = {21--38},
}

