@incollection{noauthor_monotonicity_2015,
	title = {Monotonicity and {Some} of {Its} {Consequences}},
	isbn = {978-1-119-10566-4},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.1002/9781119105664.ch5},
	doi = {https://doi.org/10.1002/9781119105664.ch5},
	abstract = {Summary This chapter examines what is meant by monotonicity and discusses some of its general consequences for a formal model of linguistic knowledge. It explains the linguistic significance of this formal property of monotonicity. F-structures are formal models of the internal structures of language, and these reflect meaningful grammatical relations. The monotonicity of the mapping from strings to f-structures implies that the grammatical relations of parts are preserved in the whole. The chapter observes several other very general consequences of the design features built into the formal architecture of lexical-functional grammar (LFG). Compositionality of predication relations in the constituent structure is a defining property of many grammatical architectures. However, LFG has been deliberately designed as a noncompositional grammatical architecture, for the reason that the typological diversity of syntactic structures we find across languages motivates a more flexible design of grammar than strict compositionality allows.},
	booktitle = {Lexical‐{Functional} {Syntax}},
	publisher = {John Wiley \& Sons, Ltd},
	year = {2015},
	note = {Section: 5
\_eprint: https://onlinelibrary.wiley.com/doi/pdf/10.1002/9781119105664.ch5},
	keywords = {functional information, grammatical relation changes, lexical-functional grammar, linguistic knowledge, monotonicity, syntactic structures},
	pages = {73--85},
}

@incollection{noauthor_formal_2015,
	title = {A {Formal} {Model} of {Syntactic} {Structure}},
	isbn = {978-1-119-10566-4},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.1002/9781119105664.ch4},
	doi = {https://doi.org/10.1002/9781119105664.ch4},
	abstract = {Summary This chapter defines the original c-structure to f-structure correspondence of lexical-functional grammar (LFG). The formal model of LFG embodies three general design principles: variability, universality, and monotonicity. The modes of expression of a language have a structure which we have called the “expression structure” or external structure. A commonly used representation of c-structure is the context-free phrase structure tree. The principle of universality states that internal structures are largely invariant across languages. The chapter defines f-structures that contain (grammatical) functions, and that suggests a reason for the name “functional” structure. f-structures are described by specifying the value it associates with each argument. The chapter explains the correspondence between a c-structure and f-structure for the sentence 'Lions live in the forest'. It then focuses on the derivation of an f-structure from a c-structure. It concludes with a discussion on completeness and coherence, functional uncertainty and sets of f-structures.},
	booktitle = {Lexical‐{Functional} {Syntax}},
	publisher = {John Wiley \& Sons, Ltd},
	year = {2015},
	note = {Section: 4
\_eprint: https://onlinelibrary.wiley.com/doi/pdf/10.1002/9781119105664.ch4},
	keywords = {c-structure, f-structures, functional uncertainty, monotonicity, syntactic structure},
	pages = {41--72},
}

