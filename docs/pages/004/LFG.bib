@incollection{noauthor_argument_2015,
	title = {From {Argument} {Structure} to {Functional} {Structure}},
	isbn = {978-1-119-10566-4},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.1002/9781119105664.ch14},
	doi = {https://doi.org/10.1002/9781119105664.ch14},
	abstract = {Summary Functional structures come from the lexical mapping theory (LMT), which projects skeletal f-structures from argument structures by general principles. This idea is illustrated in terms of the contrast between English and Warlpiri. There are varying conceptions of what argument structure is, even among researchers working within lexical-functional grammar (LFG). The reason for this is that argument structure has two faces, semantic and syntactic. On the semantic side, argument structure represents the core participants in events/states/processes designated by a single predicator. On the syntactic side, argument structure represents the minimal information needed to characterize the syntactic dependents of an argument-taking head. A-structures in LFG must have sufficient syntactic information to support the direct mapping to surface functions. The chapter suggests that there might be general principles for selecting grammatical functions from argument structures, and the first convincing instantiation of such principles is found in the work of Zaenen et al.},
	booktitle = {Lexical‐{Functional} {Syntax}},
	publisher = {John Wiley \& Sons, Ltd},
	year = {2015},
	note = {Section: 14
\_eprint: https://onlinelibrary.wiley.com/doi/pdf/10.1002/9781119105664.ch14},
	keywords = {English, Warlpiri, argument structure, functional structures, lexical mapping theory, lexical-functional grammar, syntactic principles, theory of a-structures},
	pages = {324--348},
}

@incollection{noauthor_anaphoric_2015,
	title = {Anaphoric {Control}},
	isbn = {978-1-119-10566-4},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.1002/9781119105664.ch13},
	doi = {https://doi.org/10.1002/9781119105664.ch13},
	abstract = {Summary This chapter examines a contrasting verbal construction that exhibits a different type of control, called anaphoric control. In English these verbal constructions are known as gerundive VPs. Anaphoric control also occurs with some infinitival constructions in English, but the gerundives make a very clear contrast. English gerundive VPs appear superficially identical to participial VPs. Since passivization involves the alternation of SUBJ and OBJ functions in English, the nominal nature of gerundives would immediately explain why they contrast with participials in passivization. Functional control identifies the f-structures of the controller and the controlled, while anaphoric control is like pronominal binding: only the referential index of the controller and controlled are identified. Thus, f-structure attributes such as case are expected to be shared in functional control, but not in anaphoric control. The Icelandic problem of Problem Set 5 contains an excellent illustration of this important point.},
	booktitle = {Lexical‐{Functional} {Syntax}},
	publisher = {John Wiley \& Sons, Ltd},
	year = {2015},
	note = {Section: 13
\_eprint: https://onlinelibrary.wiley.com/doi/pdf/10.1002/9781119105664.ch13},
	keywords = {English, Problem Set 5, anaphoric control, functional predication, gerundive, participial vp complements, verbal construction},
	pages = {309--323},
}

@incollection{noauthor_predication_2015,
	title = {Predication {Relations}},
	isbn = {978-1-119-10566-4},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.1002/9781119105664.ch12},
	doi = {https://doi.org/10.1002/9781119105664.ch12},
	abstract = {Summary This chapter highlights that there is evidence from binding patterns for a complement function called the 'predicate complement' in traditional grammar and the XCOMP in lexical-functional grammar (LFG). The predicate complement constitutes a second nucleus of predication within its clause. Predicate complements are phrasal categories of a type that inherently lack an internal c-structure subject. A shared argument has simultaneous functions in two different nuclei. To explain the parallel binding patterns across predicate complements of all categories, the authors have assumed that the lexical forms of verbal and adjectival xcomps have a SUBJ argument, and they have further hypothesized that prepositions have a predicative use in which their lexical form is augmented by a subject of predication. Evidence from binding, raising, and passivization supports the theory of predicate complements as having an f-structure subject of predication identified with an argument of the higher clause.},
	booktitle = {Lexical‐{Functional} {Syntax}},
	publisher = {John Wiley \& Sons, Ltd},
	year = {2015},
	note = {Section: 12
\_eprint: https://onlinelibrary.wiley.com/doi/pdf/10.1002/9781119105664.ch12},
	keywords = {PP complements, XCOMPs, c-structure, f-structure, lexical-functional grammar, lexically governed predication relations, predicate adjuncts, predicate complements},
	pages = {286--308},
}

@incollection{noauthor_types_2015,
	title = {Types of {Bound} {Anaphors}},
	isbn = {978-1-119-10566-4},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.1002/9781119105664.ch11},
	doi = {https://doi.org/10.1002/9781119105664.ch11},
	abstract = {Summary A major deficiency of the toy binding theory is that it is based almost entirely on a conception of anaphoric binding that comes from English. Yet it turns out that among systems of bound anaphors across languages, English reflexives constitute a special case. Three dimensions play a central role in anaphoric binding systems. This chapter discusses three dimensions that play a central role in anaphoric binding systems. These three dimensions define a space of possible anaphors. The chapter talks about subjectivity and logophoricity. Reflexive and nonreflexive pronouns in Icelandic illustrate the subjective dimension of the binding space. The Norwegian anaphoric binding system involves both subjectivity and nuclearity: subject anaphors can be nuclear or nonnuclear, and there is an anti-subjective nuclear anaphor. Five sentence structure types that illustrate the basic properties of the anaphoric binding system are described.},
	booktitle = {Lexical‐{Functional} {Syntax}},
	publisher = {John Wiley \& Sons, Ltd},
	year = {2015},
	note = {Section: 11
\_eprint: https://onlinelibrary.wiley.com/doi/pdf/10.1002/9781119105664.ch11},
	keywords = {English reflexives, Norwegian anaphoric binding system, anti-subjective pronouns, bound anaphors, logophoricity, nuclearity},
	pages = {254--285},
}

@incollection{noauthor_basic_2015,
	title = {Basic {Binding} {Theory}},
	isbn = {978-1-119-10566-4},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.1002/9781119105664.ch10},
	doi = {https://doi.org/10.1002/9781119105664.ch10},
	abstract = {Summary The binding theory of transformational generative grammar refers to a selected class of phrase structure positions (argument and nonargument positions), a relation of relative prominence among them (c-command), a typology of the elements that enter into binding relations (anaphors, pronominals, referring expressions), and designated regions of phrase structure within which the binding relations hold for these elements. This chapter begins with a preliminary version of the binding theory which, although it is inadequate, illustrates certain essential concepts of a binding theory within the architecture of lexical-functional grammar (LFG). Notwithstanding the inadequacies of this theory, the exercise of reformulating it in the present framework is useful. For this binding theory it is assumed that there is an index attribute whose value determines coindexing relations. Despite its textbook status, the familiar binding theory is problematic. One reason for its inadequacy is typological.},
	booktitle = {Lexical‐{Functional} {Syntax}},
	publisher = {John Wiley \& Sons, Ltd},
	year = {2015},
	note = {Section: 10
\_eprint: https://onlinelibrary.wiley.com/doi/pdf/10.1002/9781119105664.ch10},
	keywords = {basic binding theory, binding principles, lexical-functional grammar, phrase structure, transformational generative grammar},
	pages = {229--253},
}

