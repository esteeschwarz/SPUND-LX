@incollection{noauthor_topicalization_2015,
	title = {Topicalization and {Scrambling}},
	isbn = {978-1-119-10566-4},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.1002/9781119105664.ch9},
	doi = {https://doi.org/10.1002/9781119105664.ch9},
	abstract = {Summary This chapter examines a different way in which inflectional morphology determines the same kinds of functional structures as syntactic categories, through dependent-marking. Languages need not employ extraction to identify a DF with a non-DF function, if they make use of nonconfigurational means of function specification. The chapter examines the effects of economy of expression in two cases. It offers some insight into the typological shift that a language may undergo when it loses its case system and abandons the dependent-marking schemata for function specification. Topicalization involves a constituent appearing in a fixed prominent position, usually sentence- or clause-initial. In contrast, scrambling involves the ordering of argument constituents in a variety of medial adjoined positions. In English, unlike German, clause-internal topicalization of an object binder over a subject constituent containing a possessive pronoun prevents binding.},
	booktitle = {Lexical‐{Functional} {Syntax}},
	publisher = {John Wiley \& Sons, Ltd},
	year = {2015},
	note = {Section: 9
\_eprint: https://onlinelibrary.wiley.com/doi/pdf/10.1002/9781119105664.ch9},
	keywords = {English topicalization, Russian topicalization, economy of expression, inflectional morphology, languages, possessive pronoun, scrambling},
	pages = {196--226},
}

@incollection{noauthor_pronoun_2015,
	title = {Pronoun {Incorporation} and {Agreement}},
	isbn = {978-1-119-10566-4},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.1002/9781119105664.ch8},
	doi = {https://doi.org/10.1002/9781119105664.ch8},
	abstract = {Summary This chapter deals with a widespread typological phenomenon called pronoun incorporation or pronominal inflection. Verbal agreement systems evolve historically from the morphological incorporation of pronouns into verbs or other heads. One trace of this historical evolution is the frequently found formal similarity between bound pronominal inflections and syntactically independent pronouns in the same language. The principle of economy of expression requires that all syntactic phrase structure nodes contribute to completeness, coherence, or semantic expressivity; nodes that immediately dominate lexical material are exempt. Chichewa, a Bantu language of Malawi and neighboring areas of eastern central Africa, is a configurational, head-marking language. Like Chichewa, Navajo is a configurational head-marking language with no morphological case. Navajo is strictly head-final. Plains Cree is a member of Algonquian, perhaps the best-studied group of inverse agreement languages. The chapter concludes with a discussion on two types of agreement, which include Index and Concord.},
	booktitle = {Lexical‐{Functional} {Syntax}},
	publisher = {John Wiley \& Sons, Ltd},
	year = {2015},
	note = {Section: 8
\_eprint: https://onlinelibrary.wiley.com/doi/pdf/10.1002/9781119105664.ch8},
	keywords = {Chichewa, Concord, Index, Navajo, Plains Cree, pronoun incorporation},
	pages = {151--195},
}

@incollection{noauthor_endocentricity_2015,
	title = {Endocentricity and {Heads}},
	isbn = {978-1-119-10566-4},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.1002/9781119105664.ch7},
	doi = {https://doi.org/10.1002/9781119105664.ch7},
	abstract = {Summary The imperfect correspondence between c-structure and f-structure explains two types of interesting phenomena that have been observed within a single functional domain: head mobility and distributed exponence. Both phenomena can be seen as consequences of the same general principles for sharing f-structure head properties in a complex c-structural domain. This chapter examines a case of head mobility that occurs in Welsh. The mobility of heads within their functional domains naturally raises questions about the status of the phrases with missing heads. The problem that head mobility poses for endocentricity can be resolved by recovering the head of a locally headless phrase from the inverse image of the f-structure of the phrase. The Wambaya auxiliary has no morphological head/base, but is simply a cluster of clitics and suffixes marking some combination of tense, aspect, mood, directional information, and subject and object information.},
	booktitle = {Lexical‐{Functional} {Syntax}},
	publisher = {John Wiley \& Sons, Ltd},
	year = {2015},
	note = {Section: 7
\_eprint: https://onlinelibrary.wiley.com/doi/pdf/10.1002/9781119105664.ch7},
	keywords = {Wambaya auxiliary, c-structure, distributed exponence, endocentricity, f-structure, head mobility},
	pages = {129--150},
}

@incollection{noauthor_theory_2015,
	title = {A {Theory} of {Structure}–{Function} {Mappings}},
	isbn = {978-1-119-10566-4},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.1002/9781119105664.ch6},
	doi = {https://doi.org/10.1002/9781119105664.ch6},
	abstract = {Summary This chapter outlines a particular theory of c-structure to f-structure mappings based on specific principles. A theory of c-structure to f-structure mappings begins with the definition of the f-structure functions. The chapter also outlines basics of the theory of grammatical functions assumed here. C-structure categories can be organized endocentrically or lexocentrically. Endocentric organization appears in highly hierarchical c-structures. Lexocentric organization appears in flat c-structures with all arguments being sisters of the verb. Any c-structure pattern can be considered unmarked if it is an instantiation of these universal endocentric constraints. The categories and principles proposed here restrict endocentric c-structures crosslinguistically. With these principles, the grammar of a given language need not specify either the structures or the general structure–function associations of the endocentric pattern. The chapter concludes with a discussion on the effects of the principle of economy of expression.},
	booktitle = {Lexical‐{Functional} {Syntax}},
	publisher = {John Wiley \& Sons, Ltd},
	year = {2015},
	note = {Section: 6
\_eprint: https://onlinelibrary.wiley.com/doi/pdf/10.1002/9781119105664.ch6},
	keywords = {c-structure, f-structure mappings, grammatical functions, lexocentricity, principle of economy of expression},
	pages = {89--128},
}

