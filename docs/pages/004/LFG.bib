@article{belyaev_introduction_2023,
	address = {Berlin},
	title = {Introduction to {LFG}},
	url = {https://zenodo.org/records/10185934},
	doi = {10.5281/zenodo.10185934},
	abstract = {This chapter provides a general summary of the architecture of LFG. It is mainly focused on describing the two main syntactic levels, c- and f-structure, and the projection architecture used in LFG in general. It also describes the notation for defining the range of possible c-structures and their corresponding f-structures. Core syntactic mechanisms such as structure sharing and X-bar theory are also briefly covered.},
	language = {eng},
	urldate = {2026-05-02},
	journal = {Handbook of Lexical Functional Grammar},
	publisher = {Language Science Press},
	author = {Belyaev, Oleg},
	month = nov,
	year = {2023},
	note = {Belyaev 2023a.pdf},
	pages = {3--22},
}

@article{belyaev_core_2023,
	address = {Berlin},
	title = {Core concepts of {LFG}},
	url = {https://zenodo.org/records/10185936},
	doi = {10.5281/zenodo.10185936},
	abstract = {This chapter provides an in-depth coverage of the main features of the LFG framework, focusing mainly on its syntactic representations: c- and f-structure. The makeup of each level is discussed in detail. For c-structure, I describe the version of X\$'\$ theory used in LFG and the status of lexical integrity as a core principle of the framework. I discuss the notion of f-structure as a function/set of feature-value pairs that is used in the majority of LFG work; attribute value types and well-formedness conditions on f-structure (Uniqueness, Completeness and Coherence) are covered as well. I also describe the metalanguage for defining f-structures and the mapping from c- to f-structures, and note some linguistically relevant consequences of how this mapping is organized. Three proposed extensions of the standard architecture are also discussed: templates (constructions), minimal c-structure, and lexical sharing.},
	language = {eng},
	urldate = {2026-05-02},
	journal = {Handbook of Lexical Functional Grammar},
	publisher = {Language Science Press},
	author = {Belyaev, Oleg},
	month = nov,
	year = {2023},
	note = {Belyaev 2023b(1).pdf},
	pages = {23--96},
}

@article{borjars_lexical-functional_2020,
	title = {Lexical-{Functional} {Grammar}: {An} {Overview}},
	volume = {6},
	issn = {2333-9683},
	shorttitle = {Lexical-{Functional} {Grammar}},
	doi = {10.1146/annurev-linguistics-062419-125014},
	abstract = {Lexical-Functional Grammar (LFG) is a model for the analysis of language in which different types of linguistic information are represented in separate dimensions, each with its own formalism. These dimensions are linked by mapping principles. In this article, I describe the architecture of the model and illustrate some dimensions of information and the mapping between them in more detail. I also provide an outline of the analysis of long-distance dependencies and control to illustrate the advantages of this type of model. I briefly mention some further areas where LFG has proven to be a useful tool for analysis and provide references for the reader to follow up.},
	language = {eng},
	number = {1},
	journal = {Annual review of linguistics},
	publisher = {Annual Reviews},
	author = {Börjars, Kersti},
	year = {2020},
	note = {Boerjars 2020 LFG Annual Review 6\_1.pdf},
	pages = {155--172},
}

